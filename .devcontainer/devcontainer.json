{
  "name": "DATA 730 assignment",
  "image": "ghcr.io/prefix-dev/pixi:latest",
  "onCreateCommand": "pixi install --locked || pixi install",
  "postAttachCommand": {
    "jupyterlab": "pixi run lab"
  },
  "forwardPorts": [8888],
  "portsAttributes": {
    "8888": {
      "label": "JupyterLab",
      "onAutoForward": "openBrowser"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-toolsai.jupyter",
        "reditorsupport.r"
      ]
    }
  }
}
